# ============================================================
# VARIABLES DE ENTORNO — Casa Caldereta
# Copia este fichero como .env en backend/ y rellena los valores
# NUNCA subas .env al repositorio
# ============================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- Base de datos (MongoDB Atlas) ---
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@cluster.mongodb.net/casa-caldereta?retryWrites=true&w=majority

# --- Autenticación JWT ---
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga_minimo_64_caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_secreto_diferente_al_anterior_minimo_64_caracteres
JWT_REFRESH_EXPIRES_IN=7d

# --- Admin (único usuario permitido) ---
ADMIN_EMAIL=tu_email@ejemplo.com
ADMIN_PASSWORD_HASH=se_genera_con_bcrypt_al_inicializar

# --- Cloudinary (gestión de imágenes) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- CORS (frontend en desarrollo y producción) ---
CORS_ORIGIN_DEV=http://localhost:4200
CORS_ORIGIN_PROD=https://casacaldereta.com

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Base de datos (MongoDB Atlas) ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/casa-caldereta?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_por_otra_cadena_aleatoria_diferente
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD_HASH=$2b$12$hash_generado_con_scripts/generate-admin.js

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN_PROD=https://casa-caldereta.com

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Sin dominio verificado usar: onboarding@resend.dev
# Con dominio verificado usar: reservas@casa-caldereta.com
RESEND_FROM_EMAIL=onboarding@resend.dev
OWNER_EMAIL=tu@email.com
# ⚠️  NO añadir RESEND_OVERRIDE_TO en Railway — es solo para desarrollo local

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Claves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Webhook secret: en Stripe Dashboard > Developers > Webhooks > tu endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Frontend URL (para Stripe Checkout success_url y cancel_url) ─────────────
# Desarrollo: http://localhost:4200
# Producción: https://casa-caldereta.com
FRONTEND_URL=https://casa-caldereta.com

# ─── Rate limiting (opcionales — estos son los valores por defecto) ────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ─── Sincronización iCal — Airbnb / Booking.com (opcionales) ───────────────────
# Pendiente: el propietario aún no ha facilitado estas URLs (2026-07-04).
# Se obtienen desde el panel de cada plataforma → "Sincronizar calendarios" → exportar/importar iCal.
# Mientras no estén definidas, el cron de sincronización no hace nada.
# AIRBNB_ICAL_URL=https://www.airbnb.com/calendar/ical/XXXXX.ics?s=XXXXX
# BOOKING_ICAL_URL=https://admin.booking.com/hotel/hoteladmin/ical.html?...
